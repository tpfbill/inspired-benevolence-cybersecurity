DATABASE_URL=postgresql://postgres:password@localhost:5432/ibc_security
JWT_SECRET=change-this-to-a-secure-random-string
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ManageEngine Integration
MANAGEENGINE_ENABLED=false
MANAGEENGINE_API_URL=https://your-manageengine-instance.com
MANAGEENGINE_API_KEY=your-api-key-here

# Email Notifications (Optional)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@company.com
EMAIL_PASSWORD=your-password
EMAIL_FROM=security@inspiredbenevolence.com
