{
  "name": "ibc-backend",
  "version": "1.0.0",
  "description": "Backend API for Inspired Benevolence Cybersecurity platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node -r dotenv/config src/database/migrate.js",
    "import:playbooks": "tsx src/scripts/import-playbooks.ts",
    "create:sample-alerts": "tsx src/scripts/create-sample-alerts.ts",
    "create:sample-incidents": "tsx src/scripts/create-sample-incidents.ts",
    "create:team-users": "tsx src/scripts/create-team-users.ts",
    "seed:roles": "tsx src/scripts/seed-default-roles.ts",
    "reset:admin": "tsx src/scripts/reset-admin-password.ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "socket.io": "^4.7.2",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
